# Railway / production environment variables (set in Railway dashboard — do not commit secrets)

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=<random-32+-chars>

# Public URL (verification emails, Google OAuth redirect). Entrypoint can derive from RAILWAY_PUBLIC_DOMAIN if unset.
APP_URL=https://your-service.up.railway.app

DATABASE_URL=<from Railway MySQL plugin>

# Brevo (use xsmtpsib-... SMTP key, not xkeysib- API key unless using BREVO_API_KEY in app)
BREVO_SMTP_USER=your-login@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-...
MAILER_FROM_ADDRESS=<verified sender in Brevo>
MAILER_FROM_NAME=FurniStyle
CONTACT_TO_ADDRESS=<inbox for contact form>
BREVO_API_KEY=

JWT_PASSPHRASE=<strong-secret-stable-across-redeploys>

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Google Cloud Console → Authorized redirect URI:
# https://<your-railway-domain>/connect/google/check

# Mobile app / API CORS (adjust for production web or RN dev)
CORS_ALLOW_ORIGIN='^https?://(your-domain\.com|localhost|127\.0\.0\.1|10\.0\.2\.2)(:[0-9]+)?$'

CUSTOMER_API_AUTO_VERIFY=false
