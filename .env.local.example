# Copy to .env.local — never commit .env.local

APP_URL=http://127.0.0.1:8000

# Brevo SMTP (xsmtpsib-... key from Brevo → SMTP & API)
BREVO_SMTP_USER=your-login@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-your-smtp-key
MAILER_FROM_ADDRESS=you@example.com

# Or Brevo HTTP API (xkeysib-... from API Keys tab)
BREVO_API_KEY=xkeysib-your-api-key

# Google OAuth (Console → redirect: http://127.0.0.1:8000/connect/google/check)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

JWT_PASSPHRASE=your-local-jwt-passphrase-matching-config-jwt-keys
