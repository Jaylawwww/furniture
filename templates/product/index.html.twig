{% extends 'base.html.twig' %}

{% block title %}Products - FurniStyle Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
    {% if isAdmin %}
        {% include '_partials/admin_sidebar.html.twig' with { active: 'products' } %}
    {% else %}
        {% include '_partials/staff_sidebar.html.twig' with { active: 'products' } %}
    {% endif %}
    <!-- Top Navigation Bar -->
    <nav class="top-navbar">
    <h1 class="page-title">Products</h1> {# or Categories #}

    <div class="user-profile">
        <div class="user-profile-wrapper">
            <img src="https://ui-avatars.com/api/?name={{ app.user.userIdentifier|url_encode }}&background=1a1a1a&color=fff" alt="User">
            <div class="user-info">
                <div class="name">{{ app.user.userIdentifier }}</div>
                <div class="role">{% if isAdmin %}Administrator{% else %}Staff{% endif %}</div>
            </div>
        </div>
        <div class="user-dropdown">
            <button class="user-dropdown-toggle" onclick="toggleUserDropdown(event)">
                <span class="dropdown-icon">▼</span>
            </button>
            <div class="user-dropdown-menu">
                <a href="{{ path('app_change_password') }}" class="user-dropdown-item"><i class="bi bi-lock"></i> Change Password</a>
                <a href="{{ path('app_logout') }}" class="user-dropdown-item logout-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </div>

</nav>


    <!-- Main Content -->
    <main class="main-content">
        <div class="section-header">
            <h2>All Products</h2>
            <a href="{{ path('app_product_new') }}" class="btn create-btn"><i class="bi bi-plus"></i> Create New Product</a>
        </div>

        {% for flash_success in app.flashes('success') %}
            <div class="alert alert-success" role="alert">{{ flash_success }}</div>
        {% endfor %}
        {% for flash_error in app.flashes('error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}

        <!-- Search and Filter Section -->
        <div class="search-filter-section">
            <form method="GET" action="{{ path('app_product_index') }}" class="search-filter-form">
                <div class="search-input-group">
                    <input 
                        type="text" 
                        name="search" 
                        placeholder="Search products by name or description..." 
                        value="{{ searchQuery }}"
                        class="search-input"
                    >
                    <button type="submit" class="btn btn-search"><i class="bi bi-search"></i> Search</button>
                </div>
                <div class="filter-group">
                    <label for="category">Filter by Category:</label>
                    <select name="category" id="category" class="filter-select" onchange="this.form.submit()">
                        <option value="">All Categories</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {% if selectedCategoryId == category.id %}selected{% endif %}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                    {% if searchQuery or selectedCategoryId %}
                        <a href="{{ path('app_product_index') }}" class="btn btn-clear">Clear Filters</a>
                    {% endif %}
                </div>
            </form>
        </div>

        {% if products is empty %}
            <p class="empty-text">
                {% if searchQuery or selectedCategoryId %}
                    Not found
                {% else %}
                    No products found. Create your first product to get started!
                {% endif %}
            </p>
        {% else %}
            <div class="product-grid">
                {% for product in products %}
                    <div class="product-card">
                        {% if product.image %}
                            <div class="product-image-wrapper">
                                <img src="{{ asset('img/' ~ product.image) }}" alt="{{ product.name }}" class="product-image" data-image-src="{{ asset('img/' ~ product.image) }}" data-product-name="{{ product.name }}">
                                <div class="image-overlay"></div>
                            </div>
                        {% else %}
                            <div class="product-image-wrapper">
                                <img src="{{ asset('img/logo.png') }}" alt="{{ product.name }}" class="product-image" style="background: #f0f0f0; padding: 2rem;">
                            </div>
                        {% endif %}

                        <div class="product-card-content">
                            <h3>{{ product.name }}</h3>
                            <p class="stock">Stock: {{ product.stock ?? 'N/A' }}</p>
                            <p class="category">Category: {{ product.category ? product.category.name : 'Uncategorized' }}</p>
                            <p class="price">₱{{ product.price }}</p>
                            {% if product.createdBy %}
                                <p class="created-by" style="padding: 0 20px; color: #6b7280; font-size: 12px; margin-top: 8px;">
                                    Created by: <strong>{{ product.createdBy.name ?: product.createdBy.email }}</strong>
                                </p>
                            {% endif %}

                            <div class="actions">
                                <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-icon" title="View"><i class="bi bi-eye"></i></a>
                                {% if isAdmin or product.createdBy == app.user %}
                                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Are you sure you want to delete this product?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                        <button class="btn btn-danger btn-icon" type="submit" title="Delete"><i class="bi bi-trash"></i></button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Image Lightbox Modal -->
            <div id="imageLightbox" class="lightbox-modal">
                <span class="lightbox-close">&times;</span>
                <img class="lightbox-content" id="lightboxImage">
                <div class="lightbox-caption" id="lightboxCaption"></div>
            </div>
        {% endif %}
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Get the lightbox modal
            const lightbox = document.getElementById('imageLightbox');
            const lightboxImage = document.getElementById('lightboxImage');
            const lightboxCaption = document.getElementById('lightboxCaption');
            const closeBtn = document.querySelector('.lightbox-close');
            const productImages = document.querySelectorAll('.product-image[data-image-src]');

            // Open lightbox when clicking on product images
            productImages.forEach(function(img) {
                img.addEventListener('click', function(e) {
                    e.stopPropagation(); // Prevent card click event
                    const imageSrc = this.getAttribute('data-image-src');
                    const productName = this.getAttribute('data-product-name');
                    
                    lightboxImage.src = imageSrc;
                    lightboxCaption.textContent = productName;
                    lightbox.classList.add('active');
                    document.body.style.overflow = 'hidden'; // Prevent background scrolling
                });
            });

            // Close lightbox when clicking the close button
            if (closeBtn) {
                closeBtn.addEventListener('click', function() {
                    closeLightbox();
                });
            }

            // Close lightbox when clicking outside the image
            lightbox.addEventListener('click', function(e) {
                if (e.target === lightbox) {
                    closeLightbox();
                }
            });

            // Close lightbox with Escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && lightbox.classList.contains('active')) {
                    closeLightbox();
                }
            });

            function closeLightbox() {
                lightbox.classList.remove('active');
                document.body.style.overflow = ''; // Restore scrolling
            }
        });
    </script>
    <script>
        (function () {
            const websocketUrl = {{ websocketUrl|default('')|json_encode|raw }};
            if (!websocketUrl) {
                return;
            }

            try {
                const ws = new WebSocket(websocketUrl + '/ws?channel=catalog');
                ws.addEventListener('message', function (event) {
                    let message = null;
                    try {
                        message = JSON.parse(event.data);
                    } catch (_error) {
                        return;
                    }

                    if (!message || message.type !== 'catalog.updated') {
                        return;
                    }

                    window.location.reload();
                });
            } catch (_error) {
                // Optional realtime enhancement only.
            }
        })();
    </script>
{% endblock %}
