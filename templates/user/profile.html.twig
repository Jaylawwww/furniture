{% extends 'base.html.twig' %}

{% block title %}My Profile - FurniStyle{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-layout">
    <aside class="sidebar">
        {% include '_partials/brand_logo.html.twig' with { variant: 'sidebar' } %}

        <ul class="sidebar-menu">
            <li>
                <a href="{{ path('app_homepage') }}">
                    <i class="bi bi-house"></i>
                    Home
                </a>
            </li>
            <li>
                <a href="{{ path('app_profile') }}" class="active">
                    <i class="bi bi-person"></i>
                    My Profile
                </a>
            </li>
            <li>
                <a href="{{ path('app_change_password') }}">
                    <i class="bi bi-lock"></i>
                    Change Password
                </a>
            </li>
        </ul>
    </aside>

    <nav class="top-navbar">
        <h1 class="page-title">My Profile</h1>

        <div class="top-navbar-right">

            <div class="user-profile">
                <div class="user-profile-wrapper">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.userIdentifier|url_encode }}&background=1a1a1a&color=fff" alt="User">
                    <div class="user-info">
                        <div class="name">{{ app.user.userIdentifier }}</div>
                        <div class="role">Customer</div>
                    </div>
                </div>
                <div class="user-dropdown">
                    <button class="user-dropdown-toggle" onclick="toggleUserDropdown(event)">
                        <span class="dropdown-icon">▼</span>
                    </button>
                    <div class="user-dropdown-menu">
                        <a href="{{ path('app_change_password') }}" class="user-dropdown-item"><i class="bi bi-lock"></i> Change Password</a>
                        <a href="{{ path('app_logout') }}" class="user-dropdown-item logout-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="form-section">
            <div class="form-container">
                <h2>Profile Information</h2>

                {% for flash_success in app.flashes('success') %}
                    <div class="alert alert-success" style="background: #10b981; color: white; padding: 12px; border-radius: 8px; margin-bottom: 20px;">
                        {{ flash_success }}
                    </div>
                {% endfor %}

                {{ form_start(form, {'attr': {'class': 'login-form'}}) }}
                    <div class="form-group">
                        {{ form_label(form.name, 'Full Name') }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.username, 'Username') }}
                        {{ form_widget(form.username) }}
                        {{ form_errors(form.username) }}
                    </div>

                    <div class="form-group">
                        <label>Email (cannot be changed)</label>
                        <input type="email" class="form-input" value="{{ user.email }}" readonly>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn create-btn">Save Changes</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}

