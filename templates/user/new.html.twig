{% extends 'base.html.twig' %}

{% block title %}Create New User - FurniStyle Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
    {% include '_partials/admin_sidebar.html.twig' with { active: 'users' } %}

    <!-- Top Navigation Bar -->
    <nav class="top-navbar">
        <h1 class="page-title">Create New User</h1>

        <div class="top-navbar-right">
            <div class="user-profile">
                <div class="user-profile-wrapper">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.userIdentifier|url_encode }}&background=1a1a1a&color=fff" alt="User">
                    <div class="user-info">
                        <div class="name">{{ app.user.userIdentifier }}</div>
                        <div class="role">Administrator</div>
                    </div>
                </div>
                <div class="user-dropdown">
                    <button class="user-dropdown-toggle" onclick="toggleUserDropdown(event)">
                        <span class="dropdown-icon">▼</span>
                    </button>
                    <div class="user-dropdown-menu">
                        <a href="{{ path('app_change_password') }}" class="user-dropdown-item"><i class="bi bi-lock"></i> Change Password</a>
                        <a href="{{ path('app_logout') }}" class="user-dropdown-item logout-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        <div class="form-section">
            <div class="form-container">
                <h2>Create New User Account</h2>

                {{ form_start(form, {'attr': {'class': 'login-form'}}) }}
                    <div class="form-group">
                        {{ form_label(form.name, 'Full Name') }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.email, 'Email Address') }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.username, 'Username') }}
                        {{ form_widget(form.username) }}
                        {{ form_errors(form.username) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.roles, 'Role') }}
                        {{ form_widget(form.roles) }}
                        {{ form_errors(form.roles) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.plainPassword, 'Password') }}
                        <div class="password-wrapper">
                            {{ form_widget(form.plainPassword, {'attr': {'id': 'newUserPassword', 'class': 'form-input'}}) }}
                            <button type="button" class="password-toggle" id="toggleNewUserPassword" aria-label="Show password">
                                <i class="bi bi-eye" id="eyeIconNewUser"></i>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword) }}
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn create-btn">Create User</button>
                        <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Cancel</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </main>

    <script>
        (function() {
            function initPasswordToggle() {
                // Use event delegation for better reliability
                document.addEventListener('click', function(e) {
                    if (e.target.closest('#toggleNewUserPassword')) {
                        const toggleBtn = e.target.closest('#toggleNewUserPassword');
                        e.preventDefault();
                        e.stopPropagation();
                        
                        const wrapper = toggleBtn.closest('.password-wrapper');
                        if (!wrapper) return;
                        
                        let input = document.getElementById('newUserPassword') ||
                                   wrapper.querySelector('input[type="password"]') ||
                                   wrapper.querySelector('input[type="text"]') ||
                                   wrapper.querySelector('input');
                        
                        if (input) {
                            const currentType = input.type || 'password';
                            const newType = currentType === 'password' ? 'text' : 'password';
                            input.type = newType;
                            
                            const eyeIcon = document.getElementById('eyeIconNewUser');
                            if (eyeIcon) {
                                if (newType === 'text') {
                                    eyeIcon.classList.remove('bi-eye');
                                    eyeIcon.classList.add('bi-eye-slash');
                                    toggleBtn.setAttribute('aria-label', 'Hide password');
                                } else {
                                    eyeIcon.classList.remove('bi-eye-slash');
                                    eyeIcon.classList.add('bi-eye');
                                    toggleBtn.setAttribute('aria-label', 'Show password');
                                }
                            }
                        }
                    }
                });
            }
            
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initPasswordToggle);
            } else {
                initPasswordToggle();
            }
        })();
    </script>
{% endblock %}

