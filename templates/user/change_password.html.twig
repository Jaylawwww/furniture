{% extends 'base.html.twig' %}

{% block title %}Change Password - FurniStyle{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/admin.css') }}">
{% endblock %}

{% block body %}
    {% set isStaff = is_granted('ROLE_STAFF') and not is_granted('ROLE_ADMIN') %}

    {% if isAdmin %}
        {% include '_partials/admin_sidebar.html.twig' %}
    {% elseif isStaff %}
        {% include '_partials/staff_sidebar.html.twig' %}
    {% else %}
        {% include '_partials/customer_sidebar.html.twig' with { active: 'change_password' } %}
    {% endif %}

    <!-- Top Navigation Bar -->
    <nav class="top-navbar">
        <h1 class="page-title">Change Password</h1>

        <div class="top-navbar-right">
            <div class="user-profile">
                <div class="user-profile-wrapper">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.userIdentifier|url_encode }}&background=1a1a1a&color=fff" alt="User">
                    <div class="user-info">
                        <div class="name">{{ app.user.userIdentifier }}</div>
                        <div class="role">
                            {% if isAdmin %}
                                Administrator
                            {% elseif isStaff %}
                                Staff
                            {% else %}
                                Customer
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="user-dropdown">
                    <button class="user-dropdown-toggle" onclick="toggleUserDropdown(event)">
                        <span class="dropdown-icon">▼</span>
                    </button>
                    <div class="user-dropdown-menu">
                        <a href="{{ path('app_change_password') }}" class="user-dropdown-item"><i class="bi bi-lock"></i> Change Password</a>
                        <a href="{{ path('app_logout') }}" class="user-dropdown-item logout-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        <div class="form-section">
            <div class="form-container">
                <h2>Change Your Password</h2>

                {% for flash_success in app.flashes('success') %}
                    <div class="alert alert-success" role="alert">{{ flash_success }}</div>
                {% endfor %}

                {% for flash_error in app.flashes('error') %}
                    <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
                {% endfor %}

                {# Only show general form errors if there are no field-specific errors #}
                {% if changePasswordForm.vars.errors|length > 0 and changePasswordForm.currentPassword.vars.errors|length == 0 and changePasswordForm.newPassword.vars.errors|length == 0 and changePasswordForm.confirmPassword.vars.errors|length == 0 %}
                    {{ form_errors(changePasswordForm) }}
                {% endif %}

                {{ form_start(changePasswordForm, {'attr': {'class': 'login-form'}}) }}
                    <div class="form-group">
                        {{ form_label(changePasswordForm.currentPassword, 'Current Password') }}
                        <div class="password-wrapper">
                            {{ form_widget(changePasswordForm.currentPassword, {'attr': {'id': 'currentPassword', 'class': 'form-input'}}) }}
                            <button type="button" class="password-toggle" id="toggleCurrentPassword" aria-label="Show password">
                                <i class="bi bi-eye" id="eyeIconCurrent"></i>
                            </button>
                        </div>
                        {{ form_errors(changePasswordForm.currentPassword) }}
                        <div id="currentPasswordError" class="form-error" style="display: none;"></div>
                    </div>

                    <div class="form-group">
                        {{ form_label(changePasswordForm.newPassword, 'New Password') }}
                        <div class="password-wrapper">
                            {{ form_widget(changePasswordForm.newPassword, {'attr': {'id': 'newPassword', 'class': 'form-input'}}) }}
                            <button type="button" class="password-toggle" id="toggleNewPassword" aria-label="Show password">
                                <i class="bi bi-eye" id="eyeIconNew"></i>
                            </button>
                        </div>
                        {{ form_errors(changePasswordForm.newPassword) }}
                        <div id="newPasswordError" class="form-error" style="display: none;"></div>
                    </div>

                    <div class="form-group">
                        {{ form_label(changePasswordForm.confirmPassword, 'Confirm New Password') }}
                        <div class="password-wrapper">
                            {{ form_widget(changePasswordForm.confirmPassword, {'attr': {'id': 'confirmPassword', 'class': 'form-input'}}) }}
                            <button type="button" class="password-toggle" id="toggleConfirmPassword" aria-label="Show password">
                                <i class="bi bi-eye" id="eyeIconConfirm"></i>
                            </button>
                        </div>
                        {{ form_errors(changePasswordForm.confirmPassword) }}
                        <div id="confirmPasswordError" class="form-error" style="display: none;"></div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn create-btn">Change Password</button>
                        <a href="{% if isAdmin %}{{ path('app_admin_dashboard') }}{% elseif isStaff %}{{ path('app_staff_profile') }}{% else %}{{ path('app_profile') }}{% endif %}" class="btn btn-secondary">Cancel</a>
                    </div>
                {{ form_end(changePasswordForm) }}
            </div>
        </div>
    </main>

    <script>
        // Toggle password visibility and validation
        (function() {
            function initPasswordToggles() {
                // Check for Symfony form errors and highlight fields
                const formGroups = document.querySelectorAll('.form-group');
                formGroups.forEach(function(group) {
                    const formErrors = group.querySelector('ul');
                    if (formErrors) {
                        const input = group.querySelector('.form-input');
                        if (input) {
                            input.style.borderColor = '#dc2626';
                            input.style.borderWidth = '2px';
                            group.classList.add('has-error');
                        }
                    }
                });
                const passwordToggles = [
                    { toggleId: 'toggleCurrentPassword', inputId: 'currentPassword' },
                    { toggleId: 'toggleNewPassword', inputId: 'newPassword' },
                    { toggleId: 'toggleConfirmPassword', inputId: 'confirmPassword' }
                ];

            // Get form inputs - try multiple ways to find them
            let currentPasswordInput = document.getElementById('currentPassword');
            let newPasswordInput = document.getElementById('newPassword');
            let confirmPasswordInput = document.getElementById('confirmPassword');
            
            // If not found by ID, try finding by name attribute (Symfony form fields)
            if (!currentPasswordInput) {
                currentPasswordInput = document.querySelector('input[name*="currentPassword"]');
            }
            if (!newPasswordInput) {
                newPasswordInput = document.querySelector('input[name*="newPassword"]');
            }
            if (!confirmPasswordInput) {
                confirmPasswordInput = document.querySelector('input[name*="confirmPassword"]');
            }
            
            const form = document.querySelector('form.login-form');

            // Error display elements
            const currentPasswordError = document.getElementById('currentPasswordError');
            const newPasswordError = document.getElementById('newPasswordError');
            const confirmPasswordError = document.getElementById('confirmPasswordError');

            // Function to show error
            function showError(errorElement, message) {
                if (errorElement) {
                    errorElement.textContent = message;
                    errorElement.style.display = 'block';
                    errorElement.style.color = '#dc2626';
                    errorElement.style.fontSize = '0.875rem';
                    errorElement.style.marginTop = '5px';
                }
            }

            // Function to hide error
            function hideError(errorElement) {
                if (errorElement) {
                    errorElement.style.display = 'none';
                    errorElement.textContent = '';
                }
            }

            // Validate password match
            function validatePasswordMatch() {
                // Re-find inputs in case they weren't found initially
                if (!newPasswordInput) {
                    newPasswordInput = document.getElementById('newPassword') || document.querySelector('input[name*="newPassword"]');
                }
                if (!confirmPasswordInput) {
                    confirmPasswordInput = document.getElementById('confirmPassword') || document.querySelector('input[name*="confirmPassword"]');
                }
                
                if (newPasswordInput && confirmPasswordInput) {
                    const newPassword = newPasswordInput.value;
                    const confirmPassword = confirmPasswordInput.value;

                    if (confirmPassword.length > 0) {
                        if (newPassword !== confirmPassword) {
                            showError(confirmPasswordError, 'New password and confirm password do not match.');
                            confirmPasswordInput.style.borderColor = '#dc2626';
                            if (newPasswordInput) {
                                newPasswordInput.style.borderColor = '#dc2626';
                            }
                            return false;
                        } else {
                            hideError(confirmPasswordError);
                            confirmPasswordInput.style.borderColor = '#e5e7eb';
                            if (newPasswordInput) {
                                newPasswordInput.style.borderColor = '#e5e7eb';
                            }
                            return true;
                        }
                    } else {
                        hideError(confirmPasswordError);
                        if (confirmPasswordInput) {
                            confirmPasswordInput.style.borderColor = '#e5e7eb';
                        }
                        return true;
                    }
                }
                return true;
            }

            // Real-time password matching validation
            if (newPasswordInput) {
                newPasswordInput.addEventListener('input', function() {
                    if (confirmPasswordInput && confirmPasswordInput.value.length > 0) {
                        validatePasswordMatch();
                    }
                });
            }

            if (confirmPasswordInput) {
                confirmPasswordInput.addEventListener('input', function() {
                    validatePasswordMatch();
                });

                confirmPasswordInput.addEventListener('blur', function() {
                    validatePasswordMatch();
                });
            }

            // Form submission validation
            if (form) {
                form.addEventListener('submit', function(e) {
                    // Re-find inputs before validation
                    if (!currentPasswordInput) {
                        currentPasswordInput = document.getElementById('currentPassword') || document.querySelector('input[name*="currentPassword"]');
                    }
                    if (!newPasswordInput) {
                        newPasswordInput = document.getElementById('newPassword') || document.querySelector('input[name*="newPassword"]');
                    }
                    if (!confirmPasswordInput) {
                        confirmPasswordInput = document.getElementById('confirmPassword') || document.querySelector('input[name*="confirmPassword"]');
                    }
                    
                    let isValid = true;

                    // Clear previous errors
                    hideError(currentPasswordError);
                    hideError(newPasswordError);
                    hideError(confirmPasswordError);

                    // Reset border colors
                    if (currentPasswordInput) currentPasswordInput.style.borderColor = '';
                    if (newPasswordInput) newPasswordInput.style.borderColor = '';
                    if (confirmPasswordInput) confirmPasswordInput.style.borderColor = '';

                    // Validate password match
                    if (!validatePasswordMatch()) {
                        isValid = false;
                    }

                    // Check if new password is at least 6 characters
                    if (newPasswordInput && newPasswordInput.value.length > 0 && newPasswordInput.value.length < 6) {
                        showError(newPasswordError, 'Password must be at least 6 characters long.');
                        newPasswordInput.style.borderColor = '#dc2626';
                        isValid = false;
                    }

                    // Check if fields are empty
                    if (currentPasswordInput && !currentPasswordInput.value.trim()) {
                        showError(currentPasswordError, 'Please enter your current password.');
                        currentPasswordInput.style.borderColor = '#dc2626';
                        isValid = false;
                    }

                    if (newPasswordInput && !newPasswordInput.value.trim()) {
                        showError(newPasswordError, 'Please enter a new password.');
                        newPasswordInput.style.borderColor = '#dc2626';
                        isValid = false;
                    }

                    if (confirmPasswordInput && !confirmPasswordInput.value.trim()) {
                        showError(confirmPasswordError, 'Please confirm your new password.');
                        confirmPasswordInput.style.borderColor = '#dc2626';
                        isValid = false;
                    }

                    if (!isValid) {
                        e.preventDefault();
                        e.stopPropagation();
                        return false;
                    }
                });
            }

            // Password toggle functionality - use event delegation for better reliability
            // Set up event delegation for all password toggles
            document.addEventListener('click', function(e) {
                if (e.target.closest('.password-toggle')) {
                    const toggleBtn = e.target.closest('.password-toggle');
                    e.preventDefault();
                    e.stopPropagation();
                    
                    // Find the input - always search fresh from the button
                    const wrapper = toggleBtn.closest('.password-wrapper');
                    if (!wrapper) return;
                    
                    // Try multiple strategies to find the input
                    let input = wrapper.querySelector('input[type="password"]') ||
                               wrapper.querySelector('input[type="text"]') ||
                               wrapper.querySelector('input');
                    
                    if (input) {
                        // Toggle password visibility
                        const currentType = input.type || 'password';
                        const newType = currentType === 'password' ? 'text' : 'password';
                        input.type = newType;
                        
                        // Toggle eye icon classes - find the correct icon based on toggle button ID
                        let eyeIcon = null;
                        if (toggleBtn.id === 'toggleCurrentPassword') {
                            eyeIcon = document.getElementById('eyeIconCurrent');
                        } else if (toggleBtn.id === 'toggleNewPassword') {
                            eyeIcon = document.getElementById('eyeIconNew');
                        } else if (toggleBtn.id === 'toggleConfirmPassword') {
                            eyeIcon = document.getElementById('eyeIconConfirm');
                        }
                        
                        if (eyeIcon) {
                            if (newType === 'text') {
                                eyeIcon.classList.remove('bi-eye');
                                eyeIcon.classList.add('bi-eye-slash');
                                toggleBtn.setAttribute('aria-label', 'Hide password');
                            } else {
                                eyeIcon.classList.remove('bi-eye-slash');
                                eyeIcon.classList.add('bi-eye');
                                toggleBtn.setAttribute('aria-label', 'Show password');
                            }
                        }
                    }
                }
            });

            // Check for server-side errors and display them - simplified and more reliable
            function displayServerErrors() {
                // Check if form errors are already displayed (Symfony form_errors)
                // Look for the current password input's parent form-group
                let currentInput = document.getElementById('currentPassword') || document.querySelector('input[name*="currentPassword"]');
                let currentPasswordFormGroup = null;
                if (currentInput) {
                    currentPasswordFormGroup = currentInput.closest('.form-group');
                }
                const hasFormError = currentPasswordFormGroup && currentPasswordFormGroup.querySelector('ul');
                
                // Only process flash messages if there are no form errors already displayed
                if (hasFormError) {
                    // Form errors are already displayed, just highlight the input
                    if (currentInput) {
                        currentInput.style.borderColor = '#dc2626';
                        currentInput.style.borderWidth = '2px';
                        setTimeout(function() {
                            currentInput.focus();
                        }, 200);
                    }
                    return; // Don't process flash messages if form errors exist
                }
                
                // Always re-find elements to ensure they exist
                const currentErrorEl = document.getElementById('currentPasswordError');
                const newErrorEl = document.getElementById('newPasswordError');
                const confirmErrorEl = document.getElementById('confirmPasswordError');
                
                // Re-find inputs if not already found
                if (!currentInput) {
                    currentInput = document.getElementById('currentPassword') || document.querySelector('input[name*="currentPassword"]');
                }
                let newInput = document.getElementById('newPassword') || document.querySelector('input[name*="newPassword"]');
                let confirmInput = document.getElementById('confirmPassword') || document.querySelector('input[name*="confirmPassword"]');
                
                // Find all error alerts (flash messages only)
                const errorAlerts = document.querySelectorAll('.alert-danger.server-error');
                
                errorAlerts.forEach(function(alert) {
                    const errorText = alert.textContent.trim();
                    const errorTextLower = errorText.toLowerCase();
                    
                    // Current password error
                    if (errorTextLower.includes('current password') || 
                        (errorTextLower.includes('incorrect') && !errorTextLower.includes('new password'))) {
                        
                        if (currentErrorEl) {
                            currentErrorEl.innerHTML = '<span style="color: #dc2626; font-size: 0.875rem;">' + errorText + '</span>';
                            currentErrorEl.style.display = 'block';
                        }
                        
                        if (currentInput) {
                            currentInput.style.borderColor = '#dc2626';
                            currentInput.style.borderWidth = '2px';
                            currentInput.style.borderStyle = 'solid';
                            setTimeout(function() {
                                currentInput.focus();
                            }, 200);
                        }
                    }
                    // Password match error
                    else if (errorTextLower.includes('do not match') || errorTextLower.includes('password and confirm')) {
                        if (confirmErrorEl) {
                            confirmErrorEl.innerHTML = '<span style="color: #dc2626; font-size: 0.875rem;">' + errorText + '</span>';
                            confirmErrorEl.style.display = 'block';
                        }
                        if (confirmInput) {
                            confirmInput.style.borderColor = '#dc2626';
                            confirmInput.style.borderWidth = '2px';
                            confirmInput.style.borderStyle = 'solid';
                        }
                        if (newInput) {
                            newInput.style.borderColor = '#dc2626';
                            newInput.style.borderWidth = '2px';
                            newInput.style.borderStyle = 'solid';
                        }
                    }
                    // Password must be different
                    else if (errorTextLower.includes('must be different') || errorTextLower.includes('different from')) {
                        if (newErrorEl) {
                            newErrorEl.innerHTML = '<span style="color: #dc2626; font-size: 0.875rem;">' + errorText + '</span>';
                            newErrorEl.style.display = 'block';
                        }
                        if (newInput) {
                            newInput.style.borderColor = '#dc2626';
                            newInput.style.borderWidth = '2px';
                            newInput.style.borderStyle = 'solid';
                        }
                    }
                });
            }
            
            // Run immediately and with delays to ensure it catches the error
            displayServerErrors();
            setTimeout(displayServerErrors, 100);
            setTimeout(displayServerErrors, 300);
            setTimeout(displayServerErrors, 600);
            
            // Also watch for any new error alerts added to the DOM
            const observer = new MutationObserver(function(mutations) {
                displayServerErrors();
            });
            
            const formContainer = document.querySelector('.form-container');
            if (formContainer) {
                observer.observe(formContainer, {
                    childList: true,
                    subtree: true
                });
            }
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initPasswordToggles);
        } else {
            initPasswordToggles();
        }
    })();
    </script>
{% endblock %}

