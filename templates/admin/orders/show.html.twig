{% extends 'base.html.twig' %}

{% block title %}Order #{{ order.id }} - FurniStyle Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/admin.css') }}">
{% endblock %}

{% block body %}
    {% include '_partials/admin_sidebar.html.twig' with { active: 'orders' } %}

    <nav class="top-navbar">
        <h1 class="page-title">Order #{{ order.id }}</h1>
        <div class="top-navbar-right">
            <a href="{{ path('app_admin_orders') }}" class="btn">← All orders</a>
        </div>
    </nav>

    <main class="main-content">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}" style="padding: 12px 16px; margin-bottom: 1rem; border-radius: 8px; background: {% if label == 'success' %}#d1fae5{% else %}#fee2e2{% endif %};">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="dashboard-grid">
            <div class="card">
                <div class="card-header"><h2>Order details</h2></div>
                <p><strong>Status:</strong> <span class="badge badge-{{ order.status }}">{{ order.status|capitalize }}</span></p>
                <p><strong>Total:</strong> ₱{{ order.totalAmount|number_format(2) }}</p>
                <p><strong>Placed:</strong> {{ order.createdAt|date('M d, Y H:i') }}</p>
                <p><strong>Updated:</strong> {{ order.updatedAt|date('M d, Y H:i') }}</p>
                {% if order.notes %}
                    <p><strong>Customer notes:</strong> {{ order.notes }}</p>
                {% endif %}
            </div>

            <div class="card">
                <div class="card-header"><h2>Customer</h2></div>
                <p><strong>Name:</strong> {{ order.user.name ?? '—' }}</p>
                <p><strong>Username:</strong> {{ order.user.username ?? '—' }}</p>
                <p><strong>Email:</strong> {{ order.user.email }}</p>
            </div>
        </div>

        <div class="card" style="margin-top: 1.5rem;">
            <div class="card-header"><h2>Line items</h2></div>
            <table class="data-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="text-align: left; padding: 12px;">Product</th>
                        <th style="text-align: left; padding: 12px;">Qty</th>
                        <th style="text-align: left; padding: 12px;">Unit price</th>
                        <th style="text-align: left; padding: 12px;">Line total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in order.items %}
                        <tr style="border-top: 1px solid #e5e7eb;">
                            <td style="padding: 12px;">{{ item.product.name }}</td>
                            <td style="padding: 12px;">{{ item.quantity }}</td>
                            <td style="padding: 12px;">₱{{ item.unitPrice|number_format(2) }}</td>
                            <td style="padding: 12px;">₱{{ item.lineTotal|number_format(2) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if order.status == 'pending' or order.status == 'confirmed' %}
            <div class="card" style="margin-top: 1.5rem;">
                <div class="card-header"><h2>Admin actions</h2></div>
                {% if order.status == 'pending' %}
                    <form method="post" action="{{ path('app_admin_order_status', { id: order.id }) }}" style="display: inline-block; margin-right: 8px;">
                        <input type="hidden" name="status" value="confirmed">
                        <input type="hidden" name="_token" value="{{ csrf_token('order_status') }}">
                        <button type="submit" class="btn">Mark as received</button>
                    </form>
                {% endif %}
                {% if order.status == 'pending' or order.status == 'confirmed' %}
                    <form method="post" action="{{ path('app_admin_order_status', { id: order.id }) }}" style="display: inline-block;">
                        <input type="hidden" name="status" value="completed">
                        <input type="hidden" name="_token" value="{{ csrf_token('order_status') }}">
                        <button type="submit" class="btn">Mark as completed</button>
                    </form>
                {% endif %}
            </div>
        {% endif %}
    </main>

    <style>
        .badge { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; }
        .badge-pending { background: #fef3c7; color: #92400e; }
        .badge-confirmed { background: #dbeafe; color: #1e40af; }
        .badge-completed { background: #d1fae5; color: #065f46; }
        .badge-cancelled { background: #fee2e2; color: #991b1b; }
    </style>
{% endblock %}
