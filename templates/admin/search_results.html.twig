{% extends 'base.html.twig' %}

{% block title %}Search Results - FurniStyle Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/admin.css') }}">
{% endblock %}

{% block body %}
    {% include '_partials/admin_sidebar.html.twig' with { active: 'dashboard' } %}

    <!-- Top Navigation Bar -->
    <nav class="top-navbar">
        <h1 class="page-title">Search Results</h1>

        <div class="top-navbar-right">
            <form method="GET" action="{{ path('app_admin_search') }}" class="dashboard-search-form">
                <div class="search-box">
                    <input type="text" name="q" placeholder="Search products, categories, users..." value="{{ query }}" class="search-input">
                    <button type="submit" class="btn-search">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
            <div class="user-profile">
                <div class="user-profile-wrapper">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.userIdentifier|url_encode }}&background=1a1a1a&color=fff" alt="User">
                    <div class="user-info">
                        <div class="name">{{ app.user.userIdentifier }}</div>
                        <div class="role">Administrator</div>
                    </div>
                </div>
                <div class="user-dropdown">
                    <button class="user-dropdown-toggle" onclick="toggleUserDropdown(event)">
                        <span class="dropdown-icon">▼</span>
                    </button>
                    <div class="user-dropdown-menu">
                        <a href="{{ path('app_change_password') }}" class="user-dropdown-item"><i class="bi bi-lock"></i> Change Password</a>
                        <a href="{{ path('app_logout') }}" class="user-dropdown-item logout-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        {% if query %}
            <div style="margin-bottom: 30px;">
                <h2 style="font-size: 20px; color: var(--text-dark); margin-bottom: 10px;">
                    Search results for: "<strong>{{ query }}</strong>"
                </h2>
                <p style="color: var(--text-gray); font-size: 14px;">
                    Found {{ totalResults }} result{% if totalResults != 1 %}s{% endif %}
                </p>
            </div>

            <!-- Products Results -->
            {% if results.products|length > 0 %}
                <div class="card" style="margin-bottom: 25px;">
                    <div class="card-header">
                        <h2><i class="bi bi-box"></i> Products ({{ results.products|length }})</h2>
                    </div>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Category</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for product in results.products %}
                                    <tr>
                                        <td>{{ product.name }}</td>
                                        <td>${{ product.price|number_format(2) }}</td>
                                        <td>{{ product.category ? product.category.name : 'N/A' }}</td>
                                        <td>
                                            <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-icon" title="View"><i class="bi bi-eye"></i></a>
                                            <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                            {% if isAdmin or product.createdBy == app.user %}
                                                <form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Are you sure you want to delete this product?');" style="display:inline;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                                    <button class="btn btn-danger btn-icon" type="submit" title="Delete"><i class="bi bi-trash"></i></button>
                                                </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}

            <!-- Categories Results -->
            {% if results.categories|length > 0 %}
                <div class="card" style="margin-bottom: 25px;">
                    <div class="card-header">
                        <h2><i class="bi bi-folder"></i> Categories ({{ results.categories|length }})</h2>
                    </div>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for category in results.categories %}
                                    <tr>
                                        <td>{{ category.getName() }}</td>
                                        <td>
                                            <a href="{{ path('app_category_show', {'id': category.id}) }}" class="btn btn-icon" title="View"><i class="bi bi-eye"></i></a>
                                            <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                            {% if isAdmin or category.createdBy == app.user %}
                                                <form method="post" action="{{ path('app_category_delete', {'id': category.id}) }}" onsubmit="return confirm('Are you sure you want to delete this category?');" style="display:inline;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                                    <button class="btn btn-danger btn-icon" type="submit" title="Delete"><i class="bi bi-trash"></i></button>
                                                </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}

            <!-- Users Results -->
            {% if results.users|length > 0 %}
                <div class="card" style="margin-bottom: 25px;">
                    <div class="card-header">
                        <h2><i class="bi bi-person"></i> Users ({{ results.users|length }})</h2>
                    </div>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Name</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for user in results.users %}
                                    <tr>
                                        <td>{{ user.email }}</td>
                                        <td>{{ user.name ?: 'N/A' }}</td>
                                        <td>
                                            {% if 'ROLE_ADMIN' in user.roles %}
                                                <span class="badge badge-admin">Admin</span>
                                            {% else %}
                                                <span class="badge badge-staff">Staff</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if user.status == 'active' %}
                                                <span class="badge badge-success">Active</span>
                                            {% elseif user.status == 'disabled' %}
                                                <span class="badge badge-danger">Disabled</span>
                                            {% else %}
                                                <span class="badge badge-secondary">Archived</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-icon" title="View"><i class="bi bi-eye"></i></a>
                                            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}

            {% if totalResults == 0 %}
                <div class="card">
                    <div class="empty-text">
                        <p style="font-size: 18px; margin-bottom: 10px;">No results found</p>
                        <p style="color: var(--text-gray); font-size: 14px;">Try searching with different keywords</p>
                    </div>
                </div>
            {% endif %}
        {% else %}
            <div class="card">
                <div class="empty-text">
                    <p style="font-size: 18px; margin-bottom: 10px;">Please enter a search query</p>
                    <p style="color: var(--text-gray); font-size: 14px;">Use the search bar above to find products, categories, or users</p>
                </div>
            </div>
        {% endif %}
    </main>
{% endblock %}
