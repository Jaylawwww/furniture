{% extends 'base.html.twig' %}

{% block title %}Logged Out - FurniStyle Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('build/admin.css') }}">
{% endblock %}

{% block body %}
<div class="logout-container">
    <div class="logout-card">
        {% include '_partials/brand_logo.html.twig' with { variant: 'logout' } %}
        <h2>You've been logged out</h2>
        <p class="logout-text">Thank you for managing FurniStyle today. See you next time!</p>

        <a href="{{ path('app_login') }}" class="btn login-btn">Log in again</a>
    </div>
</div>
{% endblock %}
