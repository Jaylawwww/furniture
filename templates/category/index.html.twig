{% extends 'base.html.twig' %}

{% block title %}Categories - FurniStyle Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
    {% if isAdmin %}
        {% include '_partials/admin_sidebar.html.twig' with { active: 'categories' } %}
    {% else %}
        {% include '_partials/staff_sidebar.html.twig' with { active: 'categories' } %}
    {% endif %}
    <!-- Top Navigation Bar -->
    <nav class="top-navbar">
    <h1 class="page-title">Categories</h1> {# or Categories #}

    <div class="user-profile">
        <div class="user-profile-wrapper">
            <img src="https://ui-avatars.com/api/?name={{ app.user.userIdentifier|url_encode }}&background=1a1a1a&color=fff" alt="User">
            <div class="user-info">
                <div class="name">{{ app.user.userIdentifier }}</div>
                <div class="role">{% if isAdmin %}Administrator{% else %}Staff{% endif %}</div>
            </div>
        </div>
        <div class="user-dropdown">
            <button class="user-dropdown-toggle" onclick="toggleUserDropdown(event)">
                <span class="dropdown-icon">▼</span>
            </button>
            <div class="user-dropdown-menu">
                <a href="{{ path('app_change_password') }}" class="user-dropdown-item"><i class="bi bi-lock"></i> Change Password</a>
                <a href="{{ path('app_logout') }}" class="user-dropdown-item logout-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </div>

</nav>



    <!-- Main Content -->
    <main class="main-content">
        <div class="section-header">
            <h2>All Categories</h2>
            <a href="{{ path('app_category_new') }}" class="btn create-btn"><i class="bi bi-plus"></i> Create New Category</a>
        </div>

        <!-- Search Section -->
        <div class="search-filter-section">
            <form method="GET" action="{{ path('app_category_index') }}" class="search-filter-form">
                <div class="search-input-group">
                    <input 
                        type="text" 
                        name="search" 
                        placeholder="Search categories by name..." 
                        value="{{ searchQuery }}"
                        class="search-input"
                    >
                    <button type="submit" class="btn btn-search"><i class="bi bi-search"></i> Search</button>
                    {% if searchQuery %}
                        <a href="{{ path('app_category_index') }}" class="btn btn-clear">Clear</a>
                    {% endif %}
                </div>
            </form>
        </div>

        {% for flash_success in app.flashes('success') %}
            <div class="alert alert-success" role="alert">{{ flash_success }}</div>
        {% endfor %}
        {% for flash_error in app.flashes('error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}

        {% if categories is empty %}
            <p class="empty-text">
                {% if searchQuery %}
                    Not found
                {% else %}
                    No categories found. Create your first category to get started!
                {% endif %}
            </p>
        {% else %}
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Products</th>
                            <th>Created By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for category in categories %}
                            <tr>
                                <td>{{ category.id }}</td>
                                <td>{{ category.name }}</td>
                                <td>{{ category.products|length }}</td>
                                <td>
                                    {% if category.createdBy %}
                                        {{ category.createdBy.name ?: category.createdBy.email }}
                                    {% else %}
                                        <span style="color: #9ca3af;">N/A</span>
                                    {% endif %}
                                </td>
                                <td class="actions">
                                    <a href="{{ path('app_category_show', {'id': category.id}) }}" class="btn btn-icon" title="View"><i class="bi bi-eye"></i></a>
                                    {% if isAdmin or category.createdBy == app.user %}
                                        <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                        <form method="post" action="{{ path('app_category_delete', {'id': category.id}) }}" onsubmit="return confirm('Are you sure you want to delete this category?');" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                            <button class="btn btn-danger btn-icon" type="submit" title="Delete"><i class="bi bi-trash"></i></button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </main>
{% endblock %}
