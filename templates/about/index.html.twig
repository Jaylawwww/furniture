{% extends 'base.html.twig' %}

{% block title %}About Us - FurniStyle{% endblock %}

{% block javascripts %}
    {# Reuse homepage assets for consistent styling #}
    {% block importmap %}{{ importmap('homepage') }}{% endblock %}
{% endblock %}

{% block body %}
<header class="main-header">
    <div class="header-container">
        {% include '_partials/brand_logo.html.twig' with { variant: 'header' } %}
        <nav class="main-nav">
            <a href="{{ path('app_homepage') }}" class="nav-link">Home</a>
            <a href="{{ path('app_homepage') }}#products" class="nav-link">Shop</a>
            <a href="{{ path('app_about') }}" class="nav-link">About</a>
            <a href="{{ path('app_contact') }}" class="nav-link">Contact</a>
            {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_dashboard') }}" class="nav-link admin-link">Admin Panel</a>
                {% elseif is_granted('ROLE_STAFF') %}
                    <a href="{{ path('app_staff_profile') }}" class="nav-link admin-link">My Profile</a>
                {% else %}
                    <a href="{{ path('app_profile') }}" class="nav-link admin-link">My Profile</a>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="nav-link logout-link">Logout</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="nav-link">Login</a>
                <a href="{{ path('app_register') }}" class="nav-link btn-nav">Register</a>
            {% endif %}
        </nav>
    </div>
</header>

<section class="about-section" style="padding-top: 110px;">
    <div class="about-container">
        <div class="about-content">
            <h2 class="section-title">About FurniStyle</h2>
            <p class="about-text">
                FurniStyle is your trusted partner in creating beautiful, functional living spaces.
                We curate furniture that blends modern design with durable craftsmanship.
            </p>
            <p class="about-text">
                We believe furniture should feel good, last long, and match your lifestyle.
                That’s why every item is chosen with comfort, quality, and practicality in mind.
            </p>

            <div class="about-stats">
                <div class="stat-item">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Happy Customers</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">1000+</div>
                    <div class="stat-label">Products</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">10+</div>
                    <div class="stat-label">Years Experience</div>
                </div>
            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; align-items: center;">
                <a href="{{ path('app_about_team') }}" class="cta-button" style="text-decoration: none;">Meet the Team</a>
                <a href="{{ path('app_homepage') }}#products" class="cta-button" style="text-decoration: none; background: transparent; border: 2px solid currentColor;">
                    Explore Collection
                </a>
            </div>
        </div>
    </div>
</section>

<footer class="main-footer" id="contact">
    <div class="footer-content">
        <p>&copy; 2025 FurniStyle. All rights reserved.</p>
    </div>
</footer>
{% endblock %}

