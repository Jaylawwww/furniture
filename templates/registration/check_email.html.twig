{% extends 'base.html.twig' %}

{% block title %}Check your email - FurniStyle{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/admin.css') }}">
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            {% include '_partials/brand_logo.html.twig' with { variant: 'login' } %}
            <h2>Check your email</h2>
            <p>We sent a <strong>verification link</strong> to confirm your account. Open it from your inbox — no code to type.</p>
            {% if email %}
                <p style="font-size: 14px; color: #555; margin-top: 12px;">Sent to: <strong>{{ email }}</strong></p>
            {% endif %}
        </div>

        {% for flash_success in app.flashes('success') %}
            <div class="alert alert-success" role="alert" style="background: #10b981; color: white; padding: 12px; border-radius: 8px; margin-bottom: 20px;">{{ flash_success }}</div>
        {% endfor %}

        {% for flash_error in app.flashes('error') %}
            <div class="alert alert-danger" role="alert" style="background: #fee2e2; color: #991b1b; padding: 12px; border-radius: 8px; margin-bottom: 20px;">{{ flash_error }}</div>
        {% endfor %}

        <p style="font-size: 14px; color: #555; margin-bottom: 20px;">
            Look for subject <strong>Confirm your FurniStyle account</strong> and tap
            <strong>Confirm my email</strong>. The link uses <strong>http://127.0.0.1:8000</strong> so you can open it in
            desktop Chrome even if you registered in the mobile app. Check <strong>Spam</strong> and <strong>Promotions</strong>.
        </p>

        {% if email %}
            <form method="post" action="{{ path('app_resend_verification') }}">
                <input type="hidden" name="email" value="{{ email }}">
                <button type="submit" class="btn btn-outline-secondary w-100">Resend verification link</button>
            </form>
        {% endif %}

        <p style="text-align: center; margin-top: 20px;">
            <a href="{{ path('app_login') }}">Back to sign in</a>
        </p>
    </div>
</div>
{% endblock %}
