###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_string
###< symfony/framework-bundle ###

###> public URL (emails, OAuth, absolute links) ###
APP_URL=http://127.0.0.1:8000
APP_PUBLIC_URL=http://127.0.0.1:8000
DEFAULT_URI=http://127.0.0.1:8000
###< public URL ###

APP_PORT=8000

###> MySQL (Docker Compose) ###
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=furnituresystem_db
MYSQL_USER=furnituresystem_user
MYSQL_PASSWORD=userpassword
###< MySQL ###

###> doctrine ###
DATABASE_URL="mysql://furnituresystem_user:userpassword@127.0.0.1:3307/furnituresystem_db?serverVersion=8.0&charset=utf8mb4"
###< doctrine ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> Brevo SMTP (put real values in .env.local) ###
BREVO_SMTP_USER=your-login@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-your-smtp-key
MAILER_DSN=brevo+smtp://your-login%40smtp-brevo.com:xsmtpsib-your-key@default
MAILER_FROM_ADDRESS=you@example.com
MAILER_FROM_NAME="FurniStyle"
CONTACT_TO_ADDRESS=you@example.com
BREVO_API_KEY=
###< Brevo ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|10\.0\.2\.2)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

CUSTOMER_API_AUTO_VERIFY=false

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase
###< lexik/jwt-authentication-bundle ###

###> google oauth ###
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_STAFF_EMAILS=
GOOGLE_OAUTH_ADMIN_EMAILS=
###< google oauth ###

###> websocket relay ###
WEBSOCKET_PUBLIC_URL=ws://127.0.0.1:8081
WEBSOCKET_BROADCAST_URL=http://127.0.0.1:8081/broadcast
WEBSOCKET_SECRET=change_me_websocket_secret
###< websocket relay ###
